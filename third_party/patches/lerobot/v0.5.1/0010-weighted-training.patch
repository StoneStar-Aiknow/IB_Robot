+def set_train_sample_weights(cfg, dataset, train_dataset, train_num_samples):
+    train_sample_weights = [1.0] * train_num_samples
+    if not cfg.custom_weights:
+        return train_sample_weights
+    if hasattr(dataset, "hf_dataset") and "training_weight" in dataset.hf_dataset.features:
+        logging.info("Found 'training_weight' in dataset. Extracting custom weights...")
+        full_weights_column = dataset.hf_dataset["training_weight"]
+        train_sample_weights = [float(full_weights_column[i]) for i in train_dataset.indices]
+
+        logging.info(f"Successfully loaded {len(train_sample_weights)} custom weights.")
+
+        if len(train_sample_weights) > 0:
+            logging.info(f"Weight stats - Max: {max(train_sample_weights)}, Min: {min(train_sample_weights)}")
+    elif len(dataset) > 0 and "training_weight" in dataset[0]:
+        logging.info("Extracting 'training_weight' by iterating (slow path)...")
+        train_sample_weights = [
+            float(dataset[i]["training_weight"])
+            for i in tqdm(train_dataset.indices, desc="Loading Weights")
+        ]
+    else:
+        logging.warning("'training_weight' not found in dataset features. Using default 1.0 weights.")
+
+    return train_sample_weights
+
