+
+def parse_hisi_om_log(log_file_path):
+    """
+    自动解析海思OM转换日志，提取所有层的Weight Scale
+    Args:
+        log_file_path: 海思OM转换日志文件路径（如om_convert.log）
+    Returns:
+        layer_weight_scale: dict，格式 {层名: Weight Scale值}
+    """
+    # 匹配层名的正则：Op[/xxx/xxx/Conv]
+    op_pattern = re.compile(r"Op\[(/[\w/\.]+/Conv)\]")
+    # 匹配Weight Scale的正则：Weight[\d+] Scale[\d\.e+-]+
+    weight_scale_pattern = re.compile(r"Weight\[\d+\] Scale\[([\d\.e+-]+)\]")
+
+    layer_weight_scale = {}
+    current_layer = None
+
+    with open(log_file_path, encoding="utf-8") as f:
+        for line in f:
+            line = line.strip()
+            # 第一步：匹配层名
+            op_match = op_pattern.search(line)
+            if op_match:
+                current_layer = op_match.group(1)
+            # 第二步：匹配该层的Weight Scale（仅当已匹配到层名时）
+            if current_layer and "Weight" in line and "Scale" in line:
+                scale_match = weight_scale_pattern.search(line)
+                if scale_match:
+                    scale_value = float(scale_match.group(1))
+                    layer_weight_scale[current_layer] = scale_value
+                    # 重置当前层，避免重复匹配
+                    current_layer = None
+
+    # 去重（同一层可能多次出现，保留最后一个值）
+    layer_weight_scale = dict(layer_weight_scale)
+    print(f"✅ 从日志中解析出 {len(layer_weight_scale)} 个层的Weight Scale：")
+    for layer, scale in layer_weight_scale.items():
+        print(f"  {layer}: {scale}")
+    return layer_weight_scale
+
+
+class QuantConstraint:
+    def __init__(
+        self, policy, accelerator, quant_param_min=5.96e-08, quant_param_max=1.31e05, hisi_log_path=None
+    ):
+        """
+        自动加载Scale：优先从海思日志解析，无日志则动态计算
+        Args:
+            hisi_log_path: 海思OM转换日志文件路径（可选）
+        """
+        self.policy = policy
+        self.accelerator = accelerator
+        self.quant_param_min = quant_param_min
+        self.quant_param_max = quant_param_max
+        self.violation_log = defaultdict(list)
+        self._target_modules = None
+        self.layer_weight_scale = {}
+
+        # 第一步：尝试从日志解析Scale
+        if hisi_log_path:
+            try:
+                self.layer_weight_scale = parse_hisi_om_log(hisi_log_path)
+            except Exception as e:
+                logging.warning(f"解析海思日志失败，将在训练中动态计算Scale：{str(e)}")
+
+    def _get_compatible_layer_types(self):
+        """获取兼容当前PyTorch版本的层类型列表"""
+        # 基础层类型（所有PyTorch版本都支持）
+        base_layers = (
+            # 卷积层
+            nn.Conv1d,
+            nn.Conv2d,
+            nn.Conv3d,
+            nn.ConvTranspose1d,
+            nn.ConvTranspose2d,
+            nn.ConvTranspose3d,
+            # 基础线性层
+            nn.Linear,
+            # BatchNorm层（包括冻结版本）
+            nn.BatchNorm1d,
+            nn.BatchNorm2d,
+            nn.BatchNorm3d,
+            # 嵌入层和归一化层
+            nn.Embedding,
+            nn.LayerNorm,
+        )
+
+        # 可选层类型（根据PyTorch版本动态添加）
+        optional_layers = []
+
+        # 处理量化线性层（版本兼容）
+        try:
+            from torch.nn import quantized
+
+            optional_layers.append(quantized.Linear)
+        except (ImportError, AttributeError):
+            logging.debug("当前PyTorch版本不支持 torch.nn.quantized.Linear，跳过该层类型")
+
+        try:
+            from torch.nn import intrinsic
+
+            optional_layers.append(intrinsic.LinearReLU)
+        except (ImportError, AttributeError):
+            logging.debug("当前PyTorch版本不支持 torch.nn.intrinsic.LinearReLU，跳过该层类型")
+
+        # 合并所有支持的层类型
+        supported_layers = base_layers + tuple(optional_layers)
+        return supported_layers
+
+    def _get_all_weighted_modules(self):
+        """自动匹配所有有权重的层（包括冻结层）"""
+        # 解包分布式封装
+        raw_model = self.accelerator.unwrap_model(self.policy, keep_fp32_wrapper=True)
+        model = raw_model.model
+
+        # 获取兼容当前版本的层类型
+        supported_layers = self._get_compatible_layer_types()
+
+        target_modules = {}
+        for name, module in model.named_modules():
+            # 特殊处理FrozenBatchNorm2d（检测类名而非继承）
+            is_frozen_bn = "FrozenBatchNorm2d" in str(type(module))
+
+            # 匹配条件：
+            # 1. 是支持的层类型 或 是FrozenBatchNorm2d
+            # 2. 有weight属性且不为None
+            if (
+                (isinstance(module, supported_layers) or is_frozen_bn)
+                and hasattr(module, "weight")
+                and module.weight is not None
+            ):
+                target_modules[name] = module
+
+        # 打印匹配结果（仅主进程）
+        if self.accelerator.is_main_process:
+            logging.info("===== 量化约束匹配结果 =====")
+            logging.info(f"匹配到 {len(target_modules)} 个有权重的层（包括冻结层）")
+            # 按类型统计
+            layer_type_count = defaultdict(int)
+            for m in target_modules.values():
+                layer_type = str(type(m).__name__)
+                layer_type_count[layer_type] += 1
+            for layer_type, count in layer_type_count.items():
+                logging.info(f"  {layer_type}: {count} 个")
+            # 单独统计冻结层
+            frozen_count = sum(1 for m in target_modules.values() if "Frozen" in str(type(m)))
+            logging.info(f"  其中冻结层数量: {frozen_count}")
+            logging.info("============================")
+
+        return target_modules
+
+    def _calculate_layer_scale_dynamically(self, module_weights):
+        """
+        动态计算层的Weight Scale（海思Scale的计算逻辑：Scale=(max-min)/4095）
+        Args:
+            module_weights: 层的权重张量（torch.Tensor）
+        Returns:
+            scale_value: 动态计算的Weight Scale
+        """
+        # 海思INT16量化的范围：-2048 ~ 2047，差值为4095
+        quant_range = 2047 - (-2048)  # = 4095
+        weights_min = torch.min(module_weights).item()
+        weights_max = torch.max(module_weights).item()
+        # 计算Scale（避免除以0，加极小值）
+        scale_value = (weights_max - weights_min) / (quant_range + 1e-15)
+        return scale_value
+
+    def clip_weights(self):
+        if self._target_modules is None:
+            self._target_modules = self._get_all_weighted_modules()
+            if not self._target_modules:
+                logging.warning("未匹配到任何有权重的层，量化裁剪未执行！")
+                return
+
+        with torch.no_grad(), self.accelerator.autocast():
+            for name, module in self._target_modules.items():
+                if "Frozen" in str(type(module)):
+                    continue
+
+                try:
+                    weights = module.weight.data
+                    device = weights.device
+                    if not torch.is_floating_point(weights):
+                        weights = weights.float()
+
+                    # 核心：自动获取该层的Scale（优先用日志解析的，无则动态计算）
+                    if name in self.layer_weight_scale:
+                        weight_scale = self.layer_weight_scale[name]
+                        # if weight_scale > 1:
+                        #     print(f"使用日志解析的Scale：层 {name} 的 Scale={weight_scale:.2f}")
+                    else:
+                        # 动态计算Scale（适配未出现在日志中的层）
+                        weight_scale = self._calculate_layer_scale_dynamically(weights)
+                        # 缓存动态计算的Scale，避免重复计算
+                        self.layer_weight_scale[name] = weight_scale
+
+                    # 计算该层的正确裁剪上下限（无需手动配置）
+                    actual_min = self.quant_param_min * weight_scale
+                    actual_max = self.quant_param_max * weight_scale
+
+                    # 计算权重的绝对值，用于后续判断
+                    abs_weights = torch.abs(weights)
+
+                    # 1. 裁剪极小权重（约束下限）
+                    below_min_mask = (abs_weights < actual_min) & (abs_weights > 1e-15)
+                    if torch.any(below_min_mask):
+                        weights[below_min_mask] = torch.sign(weights[below_min_mask]) * actual_min
+
+                    # 2. 裁剪极大权重（约束上限）
+                    above_max_mask = abs_weights > actual_max
+                    if torch.any(above_max_mask):
+                        weights[above_max_mask] = torch.sign(weights[above_max_mask]) * actual_max
+
+                    # 写回权重
+                    module.weight.data = weights.to(device)
+
+                    # 验证+日志（保留原有逻辑）
+                    post_abs_weights = torch.abs(module.weight.data)
+                    post_below_min = torch.sum(post_abs_weights < actual_min).item()
+                    still_violate = post_below_min > 0
+
+                    self.violation_log[name].append(
+                        {
+                            "actual_min": actual_min,
+                            "weight_scale": weight_scale,
+                            "post_below_min": post_below_min,
+                            "still_violate": still_violate,
+                        }
+                    )
+
+                    if self.accelerator.is_main_process and still_violate:
+                        logging.info(f"层 {name} 裁剪完成：")
+                        logging.info(f"  自动计算Scale：{weight_scale:.2f} | 正确下限：{actual_min:.8f}")
+                        logging.info(f"  裁剪后低于下限的权重数：{post_below_min} | 仍超标：{still_violate}")
+
+                except Exception as e:
+                    if self.accelerator.is_main_process:
+                        logging.error(f"层 {name} 裁剪失败：{str(e)}")
+                    continue
+
+
+def check_quant_range_violations(model, quant_min=5.96e-08, quant_max=1.31e05, device="cpu"):
+    """
+    检测模型中超出量化范围的权重层
+
+    Args:
+        model: PyTorch模型实例
+        quant_min: 量化允许的最小值（绝对值）
+        quant_max: 量化允许的最大值（绝对值）
+        device: 模型运行设备（cpu/cuda）
+
+    Returns:
+        violation_info: 包含所有超标层信息的字典
+    """
+    # 将模型设为评估模式并移至指定设备
+    model.eval()
+    model.to(device)
+
+    # 存储超标层信息
+    violation_info = defaultdict(dict)
+    total_violation_layers = 0
+
+    print("=" * 80)
+    print(f"开始检测权重超出量化范围 [{quant_min:.2e}, {quant_max:.2e}] 的层")
+    print("=" * 80)
+
+    # 遍历所有层
+    with torch.no_grad():
+        for name, module in model.named_modules():
+            # 只检查有权重的层（卷积、全连接等）
+            if hasattr(module, "weight") and module.weight is not None:
+                # 获取权重并计算绝对值
+                weights = module.weight.data.cpu().numpy()
+                abs_weights = np.abs(weights)
+
+                # 计算超标情况
+                # 低于最小值的权重
+                below_min_mask = abs_weights < quant_min
+                below_min_count = np.sum(below_min_mask)
+                below_min_ratio = below_min_count / weights.size * 100
+
+                # 高于最大值的权重
+                above_max_mask = abs_weights > quant_max
+                above_max_count = np.sum(above_max_mask)
+                above_max_ratio = above_max_count / weights.size * 100
+
+                # 记录超标层信息
+                if below_min_count > 0 or above_max_count > 0:
+                    total_violation_layers += 1
+                    violation_info[name] = {
+                        "layer_type": str(type(module)),
+                        "weight_shape": weights.shape,
+                        "total_weights": weights.size,
+                        "below_min": {
+                            "count": below_min_count,
+                            "ratio": below_min_ratio,
+                            "min_value": np.min(abs_weights[below_min_mask]) if below_min_count > 0 else None,
+                        },
+                        "above_max": {
+                            "count": above_max_count,
+                            "ratio": above_max_ratio,
+                            "max_value": np.max(abs_weights[above_max_mask]) if above_max_count > 0 else None,
+                        },
+                        "weight_stats": {
+                            "abs_min": np.min(abs_weights),
+                            "abs_max": np.max(abs_weights),
+                            "abs_mean": np.mean(abs_weights),
+                        },
+                    }
+
+                    # 打印当前层的超标信息
+                    print(f"\n【超标层】: {name}")
+                    print(f"  层类型: {violation_info[name]['layer_type'].split('.')[-1].strip('>')}")
+                    print(f"  权重形状: {violation_info[name]['weight_shape']}")
+                    print(f"  总权重数: {violation_info[name]['total_weights']}")
+                    if below_min_count > 0:
+                        print(
+                            f"  低于最小值[{quant_min:.2e}]: {below_min_count}个 ({below_min_ratio:.2f}%) | 最小绝对值: {violation_info[name]['below_min']['min_value']:.2e}"
+                        )
+                    if above_max_count > 0:
+                        print(
+                            f"  高于最大值[{quant_max:.2e}]: {above_max_count}个 ({above_max_ratio:.2f}%) | 最大绝对值: {violation_info[name]['above_max']['max_value']:.2e}"
+                        )
+                    print(
+                        f"  权重绝对值统计: 最小值={violation_info[name]['weight_stats']['abs_min']:.2e}, 最大值={violation_info[name]['weight_stats']['abs_max']:.2e}, 均值={violation_info[name]['weight_stats']['abs_mean']:.2e}"
+                    )
+
+    # 输出汇总信息
+    print("\n" + "=" * 80)
+    print(f"检测完成！共发现 {total_violation_layers} 个层的权重超出量化范围")
+    if total_violation_layers > 0:
+        print("\n超标层列表:")
+        for idx, layer_name in enumerate(violation_info.keys(), 1):
+            print(f"  {idx}. {layer_name}")
+    print("=" * 80)
+
+    return violation_info
+
+
+def save_violation_report(violation_info, save_path="quant_violation_report.txt"):
+    """
+    将超标信息保存为文本报告，方便后续分析
+
+    Args:
+        violation_info: 检测得到的超标信息字典
+        save_path: 报告保存路径
+    """
+    with open(save_path, "w", encoding="utf-8") as f:
+        f.write("模型权重量化范围超标报告\n")
+        f.write("=" * 80 + "\n\n")
+        f.write(f"量化允许范围: [{5.96e-08:.2e}, {1.31e05:.2e}]\n\n")
+
+        if not violation_info:
+            f.write("未发现任何权重超出量化范围的层\n")
+            return
+
+        f.write(f"共发现 {len(violation_info)} 个超标层:\n\n")
+        for name, info in violation_info.items():
+            f.write(f"层名称: {name}\n")
+            f.write(f"  层类型: {info['layer_type'].split('.')[-1].strip('>')}\n")
+            f.write(f"  权重形状: {info['weight_shape']}\n")
+            f.write(f"  总权重数: {info['total_weights']}\n")
+
+            if info["below_min"]["count"] > 0:
+                f.write(
+                    f"  低于最小值: {info['below_min']['count']}个 ({info['below_min']['ratio']:.2f}%) | 最小绝对值: {info['below_min']['min_value']:.2e}\n"
+                )
+            if info["above_max"]["count"] > 0:
+                f.write(
+                    f"  高于最大值: {info['above_max']['count']}个 ({info['above_max']['ratio']:.2f}%) | 最大绝对值: {info['above_max']['max_value']:.2e}\n"
+                )
+
+            f.write(
+                f"  权重绝对值统计: 最小值={info['weight_stats']['abs_min']:.2e}, 最大值={info['weight_stats']['abs_max']:.2e}, 均值={info['weight_stats']['abs_mean']:.2e}\n"
+            )
+            f.write("\n" + "-" * 60 + "\n\n")
+
+    print(f"\n超标报告已保存至: {save_path}")
+
+
+if __name__ == "__main__":
+    # 创建参数解析器
+    parser = argparse.ArgumentParser(
+        description="处理模型配置文件（必填模型路径参数）",
+        epilog="示例: python script.py --model_path=/path/to/train_config.json",
+    )
+    parser.add_argument("--model_path", type=str, help="模型训练配置文件路径")
+
+    # 解析参数
+    if len(sys.argv) == 1:
+        parser.print_help()
+        sys.exit(1)
+    args = parser.parse_args()
+    policy = get_model(args.model_path, 1)
+
+    model = policy.model
+
+    violation_info = check_quant_range_violations(
+        model=model,
+        quant_min=0.008,  # 从警告中提取的最小值
+        quant_max=1.31e05,  # 从警告中提取的最大值
+        device="cpu",  # 根据实际情况选择cpu/cuda
+    )
+
+    # 3. 保存检测报告
+    save_violation_report(violation_info, "quant_violation_report.txt")
